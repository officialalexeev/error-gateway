# ===========================================
# Error Gateway - Environment Variables
# ===========================================

# -------------------------------------------
# Docker Image Configuration
# -------------------------------------------
# These variables are used ONLY for docker-compose
# NOT used by the application itself
#
# DOCKER_REGISTRY: Custom Docker registry (optional)
#   - Empty = Docker Hub (default)
#   - Example: registry.example.com/
#   - Example: ghcr.io/username/
#
# IMAGE_TAG: Docker image tag
#   - Default: latest
#   - Example: 1.0.0, dev, etc.
DOCKER_REGISTRY=
IMAGE_TAG=latest

# -------------------------------------------
# Ports
# -------------------------------------------
BACKEND_PORT=8000

# -------------------------------------------
# Database (auto-detection)
# -------------------------------------------
# 💡 Adaptive Microservice Concept:
# - Leave POSTGRES_USER empty = SQLite mode (default, embedded) ✅
# - Set POSTGRES_USER = PostgreSQL mode (production)
#
# Tables are created automatically on startup — no migrations needed!
#
# 💡 For SQLite mode (default):
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=
# POSTGRES_HOST=
# POSTGRES_PORT=
#
# 💡 For PostgreSQL mode (production):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=error_gateway_pass
# POSTGRES_DB=error_gateway
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
#
# 💡 PostgreSQL setup (Shared mode):
# 1. Create DB: CREATE DATABASE error_gateway;
# 2. Create user: CREATE USER postgres WITH PASSWORD 'pass';
# 3. Grant: GRANT ALL PRIVILEGES ON DATABASE error_gateway TO postgres;
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# PostgreSQL query timeout (milliseconds)
# SQLite uses timeout in connect_args
DATABASE_STATEMENT_TIMEOUT=30000

# -------------------------------------------
# Redis (optional)
# -------------------------------------------
# REDIS_HOST = (empty) = in-memory rate limiting ✅
# REDIS_HOST = redis = Redis
#
# 💡 Redis supports 16 DBs (0-15):
# - Main project: redis://redis:6379/0
# - Error Gateway: redis://redis:6379/1 (isolation)
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# -------------------------------------------
# Grafana Loki (log shipping)
# -------------------------------------------
# LOKI_URL = (empty) = Loki logging disabled ✅
# LOKI_URL = http://loki:3100 = send logs to Loki
#
# 💡 Bidirectional integration with Grafana:
# 1. Grafana → Error Gateway: webhook to /api/v1/loki/webhook
# 2. Error Gateway → Loki: send error logs
#
# 💡 URL examples:
# - Local: http://localhost:3100
# - Docker: http://loki:3100
# - Production: https://loki.example.com
LOKI_URL=

# -------------------------------------------
# Telegram (notifications)
# -------------------------------------------
# Get token: @BotFather
# Get chat_id: @userinfobot
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_TOPIC_ID=

# -------------------------------------------
# Email (SMTP notifications)
# -------------------------------------------
# EMAIL_TO supports comma-separated list: user1@example.com,user2@example.com
# Each email must be in valid format (RFC 5322 simplified)
# Valid examples: user@example.com, user.name@example.com, user+tag@example.co.uk
# Invalid examples: plainaddress, @missinglocal.com, missing@domain
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=error-gateway@example.com
EMAIL_TO=admin@example.com,devops@example.com

# -------------------------------------------
# Logging
# -------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Log format:
# - "json" for production (Grafana Loki, ELK, Splunk)
# - "text" for local development
# Default: json
LOG_FORMAT=json

# -------------------------------------------
# Application
# -------------------------------------------
# How many days to store errors
ERROR_RETENTION_DAYS=30

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=100

# Interval between notifications (minutes)
NOTIFICATION_THROTTLE_MINUTES=5

# Maximum pagination limit (DoS protection)
# Protects from memory exhaustion with large limit values
MAX_PAGINATION_LIMIT=100

# -------------------------------------------
# Data Masking
# -------------------------------------------
# Enable email masking (true/false)
MASK_EMAIL=true

# Enable phone masking (true/false)
MASK_PHONE=true

# Enable credit card masking (true/false)
MASK_CREDIT_CARD=true

# Enable token/password masking (true/false)
MASK_TOKENS=true

# -------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -------------------------------------------
# Comma-separated list of allowed origins for browser clients
# Format: "https://domain1.com,https://domain2.com"
# Empty value = CORS disabled (default)
#
# 💡 When CORS is needed:
# - Web interface (admin panel) on different domain
# - Frontend: https://admin.example.com
# - Backend: https://api.error-gateway.com
#
# 💡 When CORS is NOT needed:
# - Only server-to-server communication
# - Mobile/CLI clients (not browsers)
# - Internal microservice in Docker network
CORS_ORIGINS=
